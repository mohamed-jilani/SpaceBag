{
  "expo": {
    "name": "SpaceBag",
    "slug": "spacebag",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spacebag",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spacebag.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SpaceBag utilise la caméra pour scanner les QR codes de livraison.",
        "NSLocationWhenInUseUsageDescription": "SpaceBag utilise votre localisation pour le suivi de colis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.spacebag.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-splash-screen",
      [
        "expo-camera",
        {
          "cameraPermission": "SpaceBag utilise la caméra pour scanner les QR codes de livraison."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "facebookAppId": "1637056580750095",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
